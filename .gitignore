# ── Generated / runtime state ─────────────────────────────────────────────────

# Session logs (written by hooks at runtime)
logs/

# SQLite databases (local working data)
data/*.db

# Per-documentary project outputs
projects/

# Node modules
node_modules/

# ── GSD planning scaffolding (internal build artifacts) ───────────────────────
.planning/

# ── Channel identity & working data (local, user-configured) ─────────────────
channel/

# ── Feedback signal files (cross-agent state, regenerated per session) ─────────
feedback/
.claude/feedback/

# ── Project-scoped agent memories ─────────────────────────────────────────────
.claude/project-memories/

# ── Local-only settings ───────────────────────────────────────────────────────
.claude/settings.local.json

# ── Git worktrees (ephemeral agent isolation dirs) ────────────────────────────
.claude/worktrees/

# ── Tests (local validation scripts, not versioned) ───────────────────────────
.claude/tests/
# Versioned observability suite — smoke test + fixture data are part of the branch
!.claude/tests/smoke-test-observability.js
!.claude/tests/fixtures/
!.claude/tests/fixtures/**

# ── Docs (specs, plans, roadmap — local working docs) ────────────────────────
docs/
