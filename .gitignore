# ── Generated / runtime state ─────────────────────────────────────────────────

# Session logs (written by hooks at runtime)
logs/

# SQLite databases (local working data)
data/*.db

# Per-documentary project outputs
projects/

# Python bytecode cache
__pycache__/

# Node modules
node_modules/

# ── Channel identity & working data (local, user-configured) ─────────────────
channel/

# ── Local-only settings ───────────────────────────────────────────────────────
.claude/settings.local.json
.env
.compound-engineering/*.local.yaml

# ── Git worktrees (ephemeral agent isolation dirs) ────────────────────────────
.claude/worktrees/

# ── Scratch (ephemeral agent working data) ────────────────────────────────────
.claude/scratch/

# ── Tests — ignore local ad-hoc .js scripts at the tests/ root ───────────────
.claude/tests/*.js

# ── Docs (specs, plans, roadmap — local working docs) ────────────────────────
docs/

# ── Karpathy-auto-researcher experiment lab (untracked, local-only) ──────────
.lab/
run.log
