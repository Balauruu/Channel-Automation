# ── Generated / runtime state ─────────────────────────────────────────────────

# Session logs (written by hooks at runtime)
logs/

# SQLite databases (local working data)
data/*.db

# Per-documentary project outputs
projects/

# Node modules
node_modules/

# ── GSD planning scaffolding (internal build artifacts) ───────────────────────
.planning/

# ── Strategy & competitor data (local working data) ───────────────────────────
channel/strategy/
strategy/

# ── Topic history (accumulates per user) ──────────────────────────────────────
channel/past_topics.md

# ── Reference script corpus (local voice analysis source material) ─────────────
channel/voice-analysis/

# ── Feedback signal files (cross-agent state, regenerated per session) ─────────
feedback/
.claude/feedback/

# ── Project-scoped agent memories ─────────────────────────────────────────────
.claude/project-memories/

# ── Local-only settings ───────────────────────────────────────────────────────
.claude/settings.local.json

# ── Git worktrees (ephemeral agent isolation dirs) ────────────────────────────
.claude/worktrees/

# ── Tests (local validation scripts, not versioned) ───────────────────────────
.claude/tests/
